<!DOCTYPE html>
<html>
    <head>
         <title> <%= title %></title>
    </head>
    <body>
        <h1> <%= title %></h1>
        <h2> Sent By : <%= message.user %></h2>
        <p><strong>Message:</strong> <%= message.text %></p>
        <p><small> Date : <%= message.added.toLocaleString() %> </small></p>
        <hr>
        <a href = "/" > Back To Home</a>
    </body>
</html>