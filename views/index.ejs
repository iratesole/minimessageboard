<!DOCTYPE html>
<html lang="en">
    <head>
        <title><%= title %></title>
    </head>
    <body>
        <h1> <%= title %> </h1>
        <a href = "/new" >Add New Messsage</a>
        <hr>
          
        <ul>
            <% messages.forEach((msg,index) => { %>
                <li>
                    <strong><%= msg.user %> : </strong> "<%= msg.text %>"
                    <br>
                    <small><%= msg.added.toLocaleString() %></small>
                    <br>
                    <a href="/message/<%= index %>"> Open</a>"
                </li>
                <br>
            <% }) %>
        </ul>
    </body>
</html>